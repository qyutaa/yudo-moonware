-- Utility function (нужна для IJ)
local function getClientColor() return getgenv().aim_settings.client_color end

local function preloadGifFrames(gifState)
    if not gifState or gifState.preloaded or gifState.preloading or gifState.preloadAttempted then
        return
    end

    gifState.preloadAttempted = true
    gifState.preloading = true
    task.spawn(function()
        local ok = pcall(function()
            G.CP:PreloadAsync(gifState.frames)
        end)
        gifState.preloading = false
        gifState.preloaded = ok
    end)
end

local function getGifFrame(gifState, dt)
    if not gifState or not gifState.frames or #gifState.frames == 0 then
        return nil
    end

    gifState.time = gifState.time + math.min(dt or 0.016, 0.25)
    if gifState.time >= gifState.delay then
        local steps = math.floor(gifState.time / gifState.delay)
        gifState.time = gifState.time - (steps * gifState.delay)
        gifState.index = ((gifState.index - 1 + math.min(steps, 3)) % #gifState.frames) + 1
    end

    return gifState.frames[gifState.index]
end

