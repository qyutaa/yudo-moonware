local function cacheViewmodelPart(part)
    if State.viewmodel.originals[part] then return end
    local specialMesh = part:FindFirstChildOfClass("SpecialMesh")
    State.viewmodel.originals[part] = {
        Material = part.Material,
        Color = part.Color,
        TextureID = part:IsA("MeshPart") and part.TextureID or nil,
        MaterialVariant = part.MaterialVariant,
        SpecialMesh = specialMesh and {
            TextureId = specialMesh.TextureId,
            VertexColor = specialMesh.VertexColor
        } or nil
    }
end

local function restoreViewmodelPart(part, original)
    if not (part and part.Parent and original) then return end
    pcall(function()
        part.Material = original.Material
        part.Color = original.Color
        part.MaterialVariant = original.MaterialVariant or ""
        if part:IsA("MeshPart") and original.TextureID ~= nil then
            part.TextureID = original.TextureID
        end
        local specialMesh = part:FindFirstChildOfClass("SpecialMesh")
        if specialMesh and original.SpecialMesh then
            specialMesh.TextureId = original.SpecialMesh.TextureId or ""
            specialMesh.VertexColor = original.SpecialMesh.VertexColor or Vector3.new(1, 1, 1)
        end
    end)
end

local function applyViewmodelVisual(part, desiredMaterial, desiredColor)
    pcall(function()
        if desiredMaterial then
            part.Material = desiredMaterial
        else
            part.Material = State.viewmodel.originals[part].Material
        end
        part.Color = desiredColor
        part.MaterialVariant = ""

        if part:IsA("MeshPart") then
            part.TextureID = ""
        end

        local specialMesh = part:FindFirstChildOfClass("SpecialMesh")
        if specialMesh then
            specialMesh.TextureId = ""
            specialMesh.VertexColor = Vector3.new(desiredColor.R, desiredColor.G, desiredColor.B)
        end
    end)
end

local function restoreAllViewmodelParts()
    for part, original in pairs(State.viewmodel.originals) do
        restoreViewmodelPart(part, original)
        State.viewmodel.originals[part] = nil
    end
end

local function isViewmodelCandidate(part, character, equippedTool, camera)
    if not (part and part.Parent and part:IsA("BasePart")) then
        return false
    end

    local partName = string.lower(part.Name)
    local parentName = part.Parent and string.lower(part.Parent.Name) or ""

    if nameHasHint(partName, VIEWMODEL_EXCLUDE_HINTS) or nameHasHint(parentName, VIEWMODEL_EXCLUDE_HINTS) then
        return false
    end

    if equippedTool and part:IsDescendantOf(equippedTool) then
        return true
    end

    return false
end

local function addViewmodelPartsFromSource(source, foundParts, seenParts, character, equippedTool, camera)
    if not source then return end
    for _, descendant in ipairs(source:GetDescendants()) do
        if not seenParts[descendant] and isViewmodelCandidate(descendant, character, equippedTool, camera) then
            seenParts[descendant] = true
            table.insert(foundParts, descendant)
        end
    end
end

local function findViewmodelParts()
    local camera = workspace.CurrentCamera or G.Cam
    local character = G.LP.Character
    local equippedTool = character and character:FindFirstChildOfClass("Tool")
    local foundParts = {}
    local seenParts = {}

    addViewmodelPartsFromSource(equippedTool, foundParts, seenParts, character, equippedTool, camera)

    return foundParts
end

local function updateViewmodel()
    local settings = getgenv().aim_settings
    if not settings.viewmodel_enabled then
        restoreAllViewmodelParts()
        return
    end

    local desiredMaterial = resolveViewmodelMaterial()
    local desiredColor = settings.viewmodel_color
    local activeParts = {}

    for _, part in ipairs(findViewmodelParts()) do
        activeParts[part] = true
        cacheViewmodelPart(part)
        applyViewmodelVisual(part, desiredMaterial, desiredColor)
    end

    for part, original in pairs(State.viewmodel.originals) do
        if not activeParts[part] or not part.Parent then
            restoreViewmodelPart(part, original)
            State.viewmodel.originals[part] = nil
        end
    end
end

