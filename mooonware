local function updateTargetStrafe(deltaTime)
    local s = getgenv().aim_settings
    local ts = State.targetStrafe
    local character = G.LP.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    if not s.target_strafe_enabled then
        if humanoid then
            humanoid.AutoRotate = true
        end
        ts.active = false
        ts.targetPlayer = nil
        ts.smoothedCenter = nil
        ts.lastTargetPosition = nil
        clearTargetStrafeVisuals()
        return
    end

    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not (character and humanoid and rootPart and humanoid.Health > 0) then
        if humanoid then
            humanoid.AutoRotate = true
        end
        ts.active = false
        ts.targetPlayer = nil
        ts.smoothedCenter = nil
        ts.lastTargetPosition = nil
        clearTargetStrafeVisuals()
        return
    end

    local targetPlayer = getTargetStrafePlayer()
    if not targetPlayer or not targetPlayer.Character then
        humanoid.AutoRotate = true
        ts.active = false
        ts.targetPlayer = nil
        ts.smoothedCenter = nil
        ts.lastTargetPosition = nil
        clearTargetStrafeVisuals()
        return
    end

    local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not (targetHumanoid and targetRoot and targetHumanoid.Health > 0) then
        humanoid.AutoRotate = true
        ts.active = false
        ts.targetPlayer = nil
        ts.smoothedCenter = nil
        ts.lastTargetPosition = nil
        clearTargetStrafeVisuals()
        return
    end

    if ts.targetPlayer ~= targetPlayer then
        ts.angle = 0
        ts.smoothedCenter = nil
        ts.lastTargetPosition = nil
    end

    ts.active = true
    ts.targetPlayer = targetPlayer
    ts.angle = (ts.angle + (s.target_strafe_speed * deltaTime)) % (math.pi * 2)

    local center = getTargetStrafeCenter(targetRoot)
    if not center then
        clearTargetStrafeVisuals()
        return
    end

    local rawVelocity = targetRoot.AssemblyLinearVelocity or targetRoot.Velocity
    local targetVelocity = Vector3.new(rawVelocity.X, 0, rawVelocity.Z)
    local targetSpeed = targetVelocity.Magnitude
    local currentTargetPosition = Vector3.new(targetRoot.Position.X, 0, targetRoot.Position.Z)

    -- Вычисляем реальную скорость через изменение позиции
    local derivedVelocity = Vector3.zero
    if ts.lastTargetPosition and deltaTime > 0 then
        derivedVelocity = (currentTargetPosition - ts.lastTargetPosition) / deltaTime
    end
    ts.lastTargetPosition = currentTargetPosition

    -- Используем максимальную из двух скоростей
    if derivedVelocity.Magnitude > targetSpeed then
        targetVelocity = derivedVelocity
        targetSpeed = derivedVelocity.Magnitude
    end

    -- Плавное сглаживание центра
    if not ts.smoothedCenter then
        ts.smoothedCenter = center
    else
        -- Адаптивное сглаживание
        local smoothSpeed = 15 + math.clamp(targetSpeed / 2, 0, 15)
        local smoothAlpha = math.clamp(deltaTime * smoothSpeed, 0.3, 0.95)
        ts.smoothedCenter = ts.smoothedCenter:Lerp(center, smoothAlpha)
    end

    updateTargetStrafeVisuals(targetRoot, center)

    local radius = math.max(1, s.target_strafe_radius)
    local offset = Vector3.new(math.cos(ts.angle) * radius, 0, math.sin(ts.angle) * radius)
    local desiredPosition = Vector3.new(ts.smoothedCenter.X + offset.X, rootPart.Position.Y, ts.smoothedCenter.Z + offset.Z)
    local lookAt = Vector3.new(ts.smoothedCenter.X, rootPart.Position.Y, ts.smoothedCenter.Z)

    local positionDelta = desiredPosition - rootPart.Position
    local distance = positionDelta.Magnitude
    
    -- Скорость следования
    local baseSpeed = radius * s.target_strafe_speed * 2.2
    local speedBoost = math.clamp(targetSpeed / 14, 0, 2)
    local distanceBoost = math.clamp(distance / radius, 0.7, 1.8)
    
    local maxStep = (baseSpeed + speedBoost) * distanceBoost * math.clamp(deltaTime * 60, 1, 1.5)
    
    local nextPosition = desiredPosition
    if distance > maxStep then
        nextPosition = rootPart.Position + positionDelta.Unit * maxStep
    end

    humanoid.AutoRotate = false
    rootPart.CFrame = CFrame.new(nextPosition, lookAt)
end

-- [[ TP WALK FUNCTION ]]
local tpwalkConnection = nil

local function updateTPWalk()
    if not getgenv().aim_settings.tp_walk_enabled then
        -- Отключаем если был включен
        if tpwalkConnection then
            tpwalkConnection:Disconnect()
            tpwalkConnection = nil
        end
        return
    end
    
    -- Если уже запущен, не создаем новое подключение
    if tpwalkConnection then
        return
    end
    
    -- Создаем новое подключение
    tpwalkConnection = G.RS.Heartbeat:Connect(function(delta)
        if not getgenv().aim_settings.tp_walk_enabled then
            if tpwalkConnection then
                tpwalkConnection:Disconnect()
                tpwalkConnection = nil
            end
            return
        end
        
        local character = G.LP.Character
        local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
        
        if not (character and humanoid and humanoid.Parent) then
            return
        end
        
        if humanoid.MoveDirection.Magnitude > 0 then
            local speed = getgenv().aim_settings.tp_walk_speed
            local hrp = character:FindFirstChild("HumanoidRootPart")
            
            if hrp then
                -- Сохраняем текущую позицию камеры относительно персонажа
                local cameraCFrame = G.Cam.CFrame
                local cameraOffset = cameraCFrame.Position - hrp.Position
                
                -- Двигаем персонажа
                character:TranslateBy(humanoid.MoveDirection * speed * delta * 10)
                
                -- Обновляем камеру чтобы она следовала за персонажем плавно
                G.Cam.CFrame = CFrame.new(hrp.Position + cameraOffset, hrp.Position + cameraOffset + cameraCFrame.LookVector)
            end
        end
    end)
end

function updateAimbotCamera()
    if not getgenv().aim_settings.running then
        return
    end

    -- Проверяем активацию в зависимости от режима
    local shouldAim = false
    if getgenv().aim_settings.enabled then
        local activationMode = getgenv().aim_settings.aim_activation or "RMB"
        
        if activationMode == "Auto" then
            shouldAim = true
        elseif activationMode == "RMB" then
            shouldAim = G.UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        elseif activationMode == "LMB" then
            shouldAim = G.UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
        end
    end

    if not shouldAim then
        State.LockedTarget = nil
        State.lastAimbotCFrame = nil
        return
    end

    local function isTargetValid(target)
        if not target or not target.Parent then return false end
        local character = target.Parent
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then return false end
        local player = G.Plr:GetPlayerFromCharacter(character)
        if not player or isFriend(player.Name) then return false end
        if not hasLineOfSight(target) then return false end
        return true
    end

    if getgenv().aim_settings.lock_player then
        if not isTargetValid(State.LockedTarget) then
            State.LockedTarget = getClosest()
        end
    else
        State.LockedTarget = getClosest()
    end

    if not (State.LockedTarget and isTargetValid(State.LockedTarget)) then
        State.lastAimbotCFrame = nil
        return
    end

    local activeCamera = workspace.CurrentCamera or G.Cam
    if not activeCamera then
        return
    end

    local targetPos = getgenv().aim_settings.prediction_enabled and getPredictedPosition(State.LockedTarget) or State.LockedTarget.Position

    if getgenv().aim_settings.noise_enabled then
        local noiseAmount = getgenv().aim_settings.noise_amount
        local noiseX = (math.random() - 0.5) * noiseAmount * 2
        local noiseY = (math.random() - 0.5) * noiseAmount * 2
        local noiseZ = (math.random() - 0.5) * noiseAmount * 2
        targetPos = targetPos + Vector3.new(noiseX, noiseY, noiseZ)
    end

    if getgenv().aim_settings.smooth_enabled then
        -- Используем ТЕКУЩУЮ позицию камеры (чтобы следовать за персонажем)
        local currentPos = activeCamera.CFrame.Position
        
        -- Но направление берем из сохраненного CFrame (игнорируем движения мыши)
        local currentLook = State.lastAimbotCFrame and State.lastAimbotCFrame.LookVector or activeCamera.CFrame.LookVector
        local targetLook = (targetPos - currentPos).Unit
        
        -- Плавно интерполируем направление
        local smoothLook = currentLook:Lerp(targetLook, getgenv().aim_settings.smooth_amount)
        
        -- Создаем новый CFrame с текущей позицией и плавным направлением
        State.lastAimbotCFrame = CFrame.new(currentPos, currentPos + smoothLook)
        activeCamera.CFrame = State.lastAimbotCFrame
    else
        -- Без smooth - мгновенное наведение
        activeCamera.CFrame = CFrame.new(activeCamera.CFrame.Position, targetPos)
    end
end

