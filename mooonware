-- [[ BUILD UI ]]
local startX = 50
local panelW = 200
local gap = 12

-- Переменные для анимации панелей
local panelAnimationState = "hidden" -- "hidden", "showing", "visible", "hiding"
local panelAnimationProgress = 0
local panelOriginalPositions = {}
local panelTargetPositions = {}

local function setPanelTopLeftLayout(panel, originalPosition)
    panel.frame.AnchorPoint = Vector2.new(0, 0)
    panel.frame.Position = originalPosition
end

local function setPanelCenteredLayout(panel, originalPosition)
    panel.frame.AnchorPoint = Vector2.new(0.5, 0.5)
    panel.frame.Position = UDim2.new(
        originalPosition.X.Scale,
        originalPosition.X.Offset + panel.width / 2,
        originalPosition.Y.Scale,
        originalPosition.Y.Offset + panel.frame.Size.Y.Offset / 2
    )
end

-- Функция для анимации панелей
local function animatePanels(show)
    if show then
        if panelAnimationState == "hidden" then
            -- Сразу показываем ScreenGui чтобы анимация была видна
            ScreenGui.Enabled = true
            panelAnimationState = "showing"
            panelAnimationProgress = 0
        end
    else
        if panelAnimationState == "visible" then
            panelAnimationState = "hiding"
            panelAnimationProgress = 0
        end
    end
end

-- Функция для обновления анимации панелей
local function updatePanelAnimation(deltaTime)
    local animationMode = getgenv().aim_settings.clickgui_animation
    
    if panelAnimationState == "showing" then
        panelAnimationProgress = panelAnimationProgress + deltaTime * 4 -- Скорость анимации
        
        if panelAnimationProgress >= 1 then
            panelAnimationProgress = 1
            panelAnimationState = "visible"
            for i, panel in ipairs(State.panels) do
                setPanelTopLeftLayout(panel, panelOriginalPositions[i])
                panel.uiScale.Scale = 1
                panel.frame.BackgroundTransparency = 0
            end
            return
        end
        
        if animationMode == "First" then
            -- Плавная анимация появления снизу с задержкой для каждой панели
            for i, panel in ipairs(State.panels) do
                -- Устанавливаем AnchorPoint для режима First
                panel.frame.AnchorPoint = Vector2.new(0, 0)
                
                local delay = (i - 1) * 0.1 -- Задержка между панелями
                local adjustedProgress = math.max(0, math.min(1, (panelAnimationProgress - delay) / (1 - delay)))
                
                -- Easing функция для плавности (ease out cubic)
                local easedProgress = 1 - math.pow(1 - adjustedProgress, 3)
                
                local startY = 1 + 0.1 -- Начальная позиция (ниже экрана)
                local targetY = panelOriginalPositions[i].Y.Scale
                local currentY = startY + (targetY - startY) * easedProgress
                
                panel.frame.Position = UDim2.new(
                    panelOriginalPositions[i].X.Scale,
                    panelOriginalPositions[i].X.Offset,
                    currentY,
                    panelOriginalPositions[i].Y.Offset
                )
                
                -- Сбрасываем scale и transparency для режима First
                panel.uiScale.Scale = 1
                panel.frame.BackgroundTransparency = 0
            end
        else -- animationMode == "Two"
            -- Анимация увеличения с центра
            for i, panel in ipairs(State.panels) do
                -- Устанавливаем AnchorPoint для режима Two (центр)
                setPanelCenteredLayout(panel, panelOriginalPositions[i])
                
                local delay = (i - 1) * 0.08 -- Задержка между панелями
                local adjustedProgress = math.max(0, math.min(1, (panelAnimationProgress - delay) / (1 - delay)))
                
                -- Easing функция (ease out back - небольшой overshoot)
                local easedProgress = 1 - math.pow(1 - adjustedProgress, 3)
                
                -- Начинаем с 0, увеличиваемся до 1.1, затем до 1
                local scale
                if easedProgress < 0.5 then
                    -- Первая половина: 0 -> 1.1
                    scale = easedProgress * 2 * 1.1
                else
                    -- Вторая половина: 1.1 -> 1
                    local secondHalf = (easedProgress - 0.5) * 2
                    scale = 1.1 - secondHalf * 0.1
                end
                
                panel.uiScale.Scale = scale
                panel.frame.BackgroundTransparency = math.max(0, 1 - easedProgress * 2)
                
                setPanelCenteredLayout(panel, panelOriginalPositions[i])
            end
        end
        
    elseif panelAnimationState == "hiding" then
        panelAnimationProgress = panelAnimationProgress + deltaTime * 5 -- Быстрее при скрытии
        
        if panelAnimationProgress >= 1 then
            panelAnimationProgress = 1
            panelAnimationState = "hidden"
            -- Скрываем ScreenGui только после завершения анимации
            ScreenGui.Enabled = false
        end
        
        if animationMode == "First" then
            -- Плавная анимация исчезновения вверх с задержкой для каждой панели
            for i, panel in ipairs(State.panels) do
                -- Устанавливаем AnchorPoint для режима First
                panel.frame.AnchorPoint = Vector2.new(0, 0)
                
                local delay = (i - 1) * 0.05 -- Меньшая задержка при скрытии
                local adjustedProgress = math.max(0, math.min(1, (panelAnimationProgress - delay) / (1 - delay)))
                
                -- Easing функция для плавности (ease in cubic)
                local easedProgress = math.pow(adjustedProgress, 3)
                
                local startY = panelOriginalPositions[i].Y.Scale
                local targetY = -0.5 -- Конечная позиция (выше экрана)
                local currentY = startY + (targetY - startY) * easedProgress
                
                panel.frame.Position = UDim2.new(
                    panelOriginalPositions[i].X.Scale,
                    panelOriginalPositions[i].X.Offset,
                    currentY,
                    panelOriginalPositions[i].Y.Offset
                )
                
                panel.uiScale.Scale = 1
                panel.frame.BackgroundTransparency = 0
            end
        else -- animationMode == "Two"
            -- Анимация уменьшения в центр с исчезновением
            for i, panel in ipairs(State.panels) do
                -- Устанавливаем AnchorPoint для режима Two (центр)
                setPanelCenteredLayout(panel, panelOriginalPositions[i])
                
                local delay = (i - 1) * 0.08 -- Задержка между панелями
                local adjustedProgress = math.max(0, math.min(1, (panelAnimationProgress - delay) / (1 - delay)))
                
                -- Easing функция (ease in cubic)
                local easedProgress = math.pow(adjustedProgress, 2)
                
                -- Сначала увеличиваемся на 10%, затем уменьшаемся до 30%
                local scale
                if easedProgress < 0.2 then
                    -- Первые 20%: 1 -> 1.1
                    scale = 1 + (easedProgress / 0.2) * 0.1
                else
                    -- Остальные 80%: 1.1 -> 0.3
                    local shrinkProgress = (easedProgress - 0.2) / 0.8
                    scale = 1.1 - shrinkProgress * 0.8
                end
                
                panel.uiScale.Scale = scale
                
                setPanelCenteredLayout(panel, panelOriginalPositions[i])
                
                -- Плавное исчезновение после уменьшения
                if easedProgress > 0.6 then
                    local fadeProgress = (easedProgress - 0.6) / 0.4
                    panel.frame.BackgroundTransparency = fadeProgress
                else
                    panel.frame.BackgroundTransparency = 0
                end
            end
        end
    end
end

