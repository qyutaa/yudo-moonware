-- Infinite Jump State
local IJ = {c = nil, p = nil, pc = nil}

-- Infinite Jump Functions (определяем рано чтобы использовать в основном цикле)
local function IJ_CP()
    if IJ.p then pcall(function() IJ.p:Destroy() end) IJ.p = nil end
    if IJ.pc then pcall(function() IJ.pc:Disconnect() end) IJ.pc = nil end
    if IJ.fsl then pcall(function() IJ.fsl:Disconnect() end) IJ.fsl = nil end
end

local function IJ_MkP(ch)
    IJ_CP()
    local h = ch:FindFirstChild("HumanoidRootPart")
    if not h then return end
    
    local p = Instance.new("Part")
    p.Name = "IJP"
    p.Size = Vector3.new(8, 0.5, 8)
    p.Anchored = true
    -- CanCollide зависит от режима Bypass
    p.CanCollide = not getgenv().aim_settings.infinite_jump_bypass
    p.Transparency = 1 -- Полностью невидимая
    p.Material = Enum.Material.ForceField
    p.Color = Color3.fromRGB(255, 255, 255)
    p.CastShadow = false
    p.Parent = workspace
    
    IJ.p = p
    
    IJ.pc = G.RS.Heartbeat:Connect(function()
        if not (IJ.p and ch and h) then IJ_CP() return end
        local hm = ch:FindFirstChildOfClass("Humanoid")
        if hm then
            local s = hm:GetState()
            if s == Enum.HumanoidStateType.Freefall or s == Enum.HumanoidStateType.Jumping then
                p.Position = h.Position - Vector3.new(0, 4, 0)
            else
                p.Position = h.Position - Vector3.new(0, 100, 0)
            end
        end
    end)
end

local function IJ_I()
    if IJ.c then IJ.c:Disconnect() IJ.c = nil end
    IJ_CP()
    
    if not getgenv().aim_settings.infinite_jump_enabled then return end
    
    local ch = G.LP.Character
    if not ch then return end
    local hm = ch:FindFirstChildOfClass("Humanoid")
    if not hm then return end
    
    if getgenv().aim_settings.infinite_jump_mode == "Platform" then
        IJ_MkP(ch)
    end
    
    -- Применяем силу прыжка
    local jumpPower = getgenv().aim_settings.infinite_jump_power
    if hm.UseJumpPower then
        hm.JumpPower = jumpPower
    else
        hm.JumpHeight = jumpPower / 10 -- Конвертируем для новой системы
    end
    
    -- Ограничение скорости падения для обхода детекта
    local needLimiter = getgenv().aim_settings.infinite_jump_bypass or getgenv().aim_settings.infinite_jump_mode == "Platform"
    
    if needLimiter then
        IJ.fsl = G.RS.Heartbeat:Connect(function()
            if not (ch and ch.Parent) then
                if IJ.fsl then IJ.fsl:Disconnect() IJ.fsl = nil end
                return
            end
            
            local hrp = ch:FindFirstChild("HumanoidRootPart")
            local maxFallSpeed = -getgenv().aim_settings.infinite_jump_fall_limit
            if hrp and hrp.Velocity.Y < maxFallSpeed then
                -- Ограничиваем скорость падения
                hrp.Velocity = Vector3.new(hrp.Velocity.X, maxFallSpeed, hrp.Velocity.Z)
            end
        end)
    end
    
    IJ.c = G.UIS.JumpRequest:Connect(function()
        if not getgenv().aim_settings.infinite_jump_enabled then return end
        if not (ch and hm and hm.Parent) then return end
        
        local m = getgenv().aim_settings.infinite_jump_mode
        local bypass = getgenv().aim_settings.infinite_jump_bypass
        
        if m == "Default" then
            if bypass then
                -- Обход античита: используем Velocity вместо ChangeState
                local hrp = ch:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Velocity = Vector3.new(hrp.Velocity.X, jumpPower, hrp.Velocity.Z)
                end
            else
                hm:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        elseif m == "Platform" and IJ.p then
            if bypass then
                local hrp = ch:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Velocity = Vector3.new(hrp.Velocity.X, jumpPower, hrp.Velocity.Z)
                end
            else
                hm:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end)
    
    hm.Died:Connect(function()
        IJ_CP()
        if fallSpeedLimiter then fallSpeedLimiter:Disconnect() end
    end)

end

-- Movement Functions (объединены в таблицу для экономии local)
local Movement = {}

Movement.Spider = {
    Cleanup = function()
        if State.spider then
            if State.spider.fallLimiter then State.spider.fallLimiter:Disconnect() end
            if State.spider.platformConnection then State.spider.platformConnection:Disconnect() end
            if State.spider.bypassTimer then State.spider.bypassTimer:Disconnect() end
            if State.spider.platform then pcall(function() State.spider.platform:Destroy() end) end
            State.spider = {}
        end
    end,
    Init = function()
        Movement.Spider.Cleanup()
        if not getgenv().aim_settings.spider_enabled then return end
        
        State.spider = {ch = G.LP.Character}
        if not State.spider.ch then return end
        State.spider.hm = State.spider.ch:FindFirstChildOfClass("Humanoid")
        State.spider.hr = State.spider.ch:FindFirstChild("HumanoidRootPart")
        if not State.spider.hm or not State.spider.hr then return end
        
        State.spider.fallLimiter = G.RS.Heartbeat:Connect(function()
            if not getgenv().aim_settings.spider_enabled or not (State.spider.ch and State.spider.ch.Parent and State.spider.hr) then
                Movement.Spider.Cleanup()
                return
            end
            if State.spider.hr.Velocity.Y < -getgenv().aim_settings.spider_fall_limit then
                State.spider.hr.Velocity = Vector3.new(State.spider.hr.Velocity.X, -getgenv().aim_settings.spider_fall_limit, State.spider.hr.Velocity.Z)
            end
        end)
        
        if getgenv().aim_settings.spider_mode == "Platform" then
            State.spider.platform = Instance.new("Part", workspace)
            State.spider.platform.Size = Vector3.new(8, 0.5, 8)
            State.spider.platform.Anchored = true
            State.spider.platform.CanCollide = true
            State.spider.platform.Transparency = 1
            State.spider.platform.Material = Enum.Material.ForceField
            State.spider.platform.CastShadow = false
            
            State.spider.platformConnection = G.RS.Heartbeat:Connect(function()
                if not getgenv().aim_settings.spider_enabled or not (State.spider.platform and State.spider.hr and State.spider.hr.Parent) then
                    Movement.Spider.Cleanup()
                    return
                end
                State.spider.wd = false
                for _, d in ipairs({Vector3.new(1,0,0), Vector3.new(-1,0,0), Vector3.new(0,0,1), Vector3.new(0,0,-1)}) do
                    State.spider.rp = RaycastParams.new()
                    State.spider.rp.FilterDescendantsInstances = {State.spider.ch}
                    State.spider.rp.FilterType = Enum.RaycastFilterType.Blacklist
                    if workspace:Raycast(State.spider.hr.Position, d * 3, State.spider.rp) then
                        State.spider.wd = true
                        break
                    end
                end
                State.spider.platform.Position = State.spider.wd and (State.spider.hr.Position - Vector3.new(0, 3, 0)) or (State.spider.hr.Position - Vector3.new(0, 100, 0))
            end)
        end
    end
}

Movement.AirStuck = {
    Cleanup = function()
        if State.airStuck then
            if State.airStuck.connection then State.airStuck.connection:Disconnect() end
            State.airStuck = {}
        end
    end,
    Init = function()
        Movement.AirStuck.Cleanup()
        if not getgenv().aim_settings.air_stuck_enabled then return end
        
        State.airStuck = {ch = G.LP.Character}
        if not State.airStuck.ch then return end
        State.airStuck.hr = State.airStuck.ch:FindFirstChild("HumanoidRootPart")
        if not State.airStuck.hr then return end
        
        State.airStuck.fp = State.airStuck.hr.Position
        State.airStuck.lu = tick()
        State.airStuck.mo = 0
        
        State.airStuck.connection = G.RS.Heartbeat:Connect(function()
            if not getgenv().aim_settings.air_stuck_enabled or not (State.airStuck.ch and State.airStuck.ch.Parent and State.airStuck.hr and State.airStuck.hr.Parent) then
                Movement.AirStuck.Cleanup()
                return
            end
            State.airStuck.ct = tick()
            State.airStuck.dt = State.airStuck.ct - State.airStuck.lu
            State.airStuck.lu = State.airStuck.ct
            State.airStuck.mo = State.airStuck.mo + State.airStuck.dt * 0.1
