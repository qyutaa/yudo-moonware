local function getVisibleKeybindEntries()
    local entries = {}

    local function addEntry(settingKey, keyCode, active)
        if not keyCode or keyCode == Enum.KeyCode.Unknown then
            return
        end

        table.insert(entries, {
            name = getBindDisplayName(settingKey),
            keyCode = keyCode,
            active = active == true
        })
    end

    addEntry("clickgui_enabled", getgenv().aim_settings.clickgui_bind, getgenv().aim_settings.clickgui_enabled)
    addEntry("click_action", getgenv().aim_settings.click_action_key, getgenv().aim_settings.click_action)

    for settingKey, keyCode in pairs(getgenv().aim_settings.hotkeys or {}) do
        addEntry(settingKey, keyCode, getgenv().aim_settings[settingKey])
    end

    table.sort(entries, function(a, b)
        return a.name < b.name
    end)

    return entries
end

