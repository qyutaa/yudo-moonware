-- Fly Functions (using State to avoid local variable limit)
local function Fly_Cleanup()
    if State.fly then
        if State.fly.connection then State.fly.connection:Disconnect() end
        if State.fly.bodyGyro then State.fly.bodyGyro:Destroy() end
        if State.fly.bodyVelocity then State.fly.bodyVelocity:Destroy() end
        if State.fly.platform then State.fly.platform:Destroy() end
        if State.fly.climbPart then State.fly.climbPart:Destroy() end
        if State.fly.weld then State.fly.weld:Destroy() end
        if State.fly.seat then State.fly.seat:Destroy() end
        if State.fly.bypassTimer then State.fly.bypassTimer:Disconnect() end
        if State.fly.tween then State.fly.tween:Cancel() end
        
        -- Удаляем парты из пула (для Legit режима)
        if State.fly.parts then
            for _, partData in ipairs(State.fly.parts) do
                if partData.part then
                    partData.part:Destroy()
                end
            end
        end
        
        -- Восстанавливаем состояния Humanoid
        if State.fly.hm then
            State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
            State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Flying, true)
            State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
            State.fly.hm.WalkSpeed = 16
        end
        
        State.fly = {}
    end
end

local function getFlyMoveDirection()
    State.flyDir = Vector3.new(0, 0, 0)
    if G.UIS:IsKeyDown(Enum.KeyCode.W) then State.flyDir = State.flyDir + G.Cam.CFrame.LookVector end
    if G.UIS:IsKeyDown(Enum.KeyCode.S) then State.flyDir = State.flyDir - G.Cam.CFrame.LookVector end
    if G.UIS:IsKeyDown(Enum.KeyCode.A) then State.flyDir = State.flyDir - G.Cam.CFrame.RightVector end
    if G.UIS:IsKeyDown(Enum.KeyCode.D) then State.flyDir = State.flyDir + G.Cam.CFrame.RightVector end
    if G.UIS:IsKeyDown(Enum.KeyCode.Space) then State.flyDir = State.flyDir + Vector3.new(0, 1, 0) end
    if G.UIS:IsKeyDown(Enum.KeyCode.LeftShift) then State.flyDir = State.flyDir - Vector3.new(0, 1, 0) end
    return State.flyDir
end

local function Fly_Mode_Gyro()
    State.fly.bodyGyro = Instance.new("BodyGyro", State.fly.hr)
    State.fly.bodyGyro.P = 9e4
    State.fly.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.fly.bodyVelocity = Instance.new("BodyVelocity", State.fly.hr)
    State.fly.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.bodyGyro) then Fly_Cleanup() return end
        State.fly.bodyGyro.CFrame = G.Cam.CFrame
        getFlyMoveDirection()
        
        if State.fly.bypass then
            if State.fly.bMode == "Jitter" and tick() - State.fly.lastVel > 0.03 then
                State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50) + Vector3.new(math.random(-10, 10)/10, math.random(-10, 10)/10, math.random(-10, 10)/10)
                State.fly.lastVel = tick()
            elseif State.fly.bMode == "Smooth" then
                State.fly.bodyVelocity.Velocity = State.fly.bodyVelocity.Velocity:Lerp(State.flyDir * (State.flyS.fly_speed * 50), 0.1)
            else
                State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
            end
        else
            State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
        end
    end)
end

local function Fly_Mode_CFrame()
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr) then Fly_Cleanup() return end
        getFlyMoveDirection()
        
        if State.fly.bypass then
            if State.fly.bMode == "Jitter" and tick() - State.fly.lastTouch > 0.02 then
                State.fly.hr.CFrame = State.fly.hr.CFrame + State.flyDir * State.flyS.fly_speed + Vector3.new(math.random(-5, 5)/100, math.random(-5, 5)/100, math.random(-5, 5)/100)
                State.fly.hr.Velocity = Vector3.new(0, 0, 0)
                State.fly.lastTouch = tick()
            elseif State.fly.bMode == "Smooth" then
                State.fly.hr.CFrame = CFrame.new(State.fly.hr.Position:Lerp(State.fly.hr.Position + State.flyDir * State.flyS.fly_speed * 0.5, 0.2))
                State.fly.hr.Velocity = State.flyDir * (State.flyS.fly_speed * 10)
            else
                State.fly.hr.Velocity = Vector3.new(0, 0, 0)
                State.fly.hr.CFrame = State.fly.hr.CFrame + State.flyDir * State.flyS.fly_speed
            end
        else
            State.fly.hr.Velocity = Vector3.new(0, 0, 0)
            State.fly.hr.CFrame = State.fly.hr.CFrame + State.flyDir * State.flyS.fly_speed
        end
    end)
end

local function Fly_Mode_Platform()
    State.fly.platform = Instance.new("Part", workspace)
    State.fly.platform.Size = Vector3.new(8, 0.5, 8)
    State.fly.platform.Anchored = true
    State.fly.platform.CanCollide = true
    State.fly.platform.Transparency = 1
    State.fly.platform.Material = Enum.Material.ForceField
    State.fly.platform.CastShadow = false
    
    if State.fly.bypass then
        State.fly.bypassTimer = G.RS.Heartbeat:Connect(function()
            if not State.flyS.fly_enabled then Fly_Cleanup() return end
            if State.fly.bMode == "Jitter" then
                State.fly.platform.CanCollide = math.random() > 0.3
            elseif State.fly.bMode == "Smooth" then
                State.fly.platform.Transparency = math.abs(math.sin(tick() * 2))
                State.fly.platform.CanCollide = State.fly.platform.Transparency < 0.5
            end
        end)
    end
    
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.platform) then Fly_Cleanup() return end
        getFlyMoveDirection()
        if State.flyDir.Magnitude > 0 then State.fly.hr.CFrame = State.fly.hr.CFrame + State.flyDir * State.flyS.fly_speed end
        State.fly.platform.Position = State.fly.hr.Position - Vector3.new(0, 3.5, 0)
    end)
end

local function Fly_Mode_Velocity()
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr) then Fly_Cleanup() return end
        getFlyMoveDirection()
        
        if State.fly.bypass then
            if State.fly.bMode == "Jitter" then
                State.fly.hr.Velocity = State.flyDir * (State.flyS.fly_speed * 16) + Vector3.new(math.random(-20, 20), math.random(-20, 20), math.random(-20, 20))
            elseif State.fly.bMode == "Smooth" then
                State.fly.hr.Velocity = State.fly.hr.Velocity:Lerp(State.flyDir * (State.flyS.fly_speed * 16), 0.15)
            else
                State.fly.hr.Velocity = State.flyDir * (State.flyS.fly_speed * 16)
            end
        else
            State.fly.hr.Velocity = State.flyDir * (State.flyS.fly_speed * 16)
        end
    end)
end

local function Fly_Mode_Tween()
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr) then Fly_Cleanup() return end
        getFlyMoveDirection()
        
        if State.flyDir.Magnitude > 0 then
            State.flyTargetPos = State.fly.hr.Position + State.flyDir * State.flyS.fly_speed * 2
            
            if State.fly.bypass then
                if State.fly.bMode == "Jitter" then
                    State.flyTargetPos = State.flyTargetPos + Vector3.new(math.random(-5, 5)/10, math.random(-5, 5)/10, math.random(-5, 5)/10)
                elseif State.fly.bMode == "Smooth" then
                    State.fly.hr.CFrame = State.fly.hr.CFrame:Lerp(CFrame.new(State.flyTargetPos), 0.05)
                    return
                end
            end
            
            if State.fly.tween then State.fly.tween:Cancel() end
            State.fly.tween = G.TS:Create(State.fly.hr, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = CFrame.new(State.flyTargetPos)})
            State.fly.tween:Play()
        end
    end)
end

local function Fly_Mode_Climb()
    -- Создаем ГОРИЗОНТАЛЬНЫЙ парт (как ступенька/блок)
    State.fly.climbPart = Instance.new("Part", workspace)
    State.fly.climbPart.Name = "ClimbPart"
    State.fly.climbPart.Size = Vector3.new(6, 0.4, 6) -- ГОРИЗОНТАЛЬНАЯ плитка
    State.fly.climbPart.Anchored = true
    State.fly.climbPart.CanCollide = true
    State.fly.climbPart.Transparency = 0.7 -- Видимый для дебага
    State.fly.climbPart.Color = Color3.fromRGB(0, 255, 0) -- Зеленый
    State.fly.climbPart.Material = Enum.Material.Neon
    State.fly.climbPart.CastShadow = false
    State.fly.climbPart.CanQuery = false
    
    State.fly.lastMoveDir = Vector3.new(0, 0, 1) -- Направление по умолчанию
    State.fly.lastBypassTime = tick()
    State.fly.bypassPhase = 0
    
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.climbPart) then 
            Fly_Cleanup() 
            return 
        end
        
        local hm = State.fly.hm
        if not hm then Fly_Cleanup() return end
        
        -- Получаем направление движения от Humanoid
        local moveDir = hm.MoveDirection
        
        -- Если персонаж двигается, обновляем направление
        if moveDir.Magnitude > 0.1 then
            State.fly.lastMoveDir = moveDir.Unit
        end
        
        -- Получаем размер HumanoidRootPart
        local hrpSize = State.fly.hr.Size
        local hrpRadius = math.max(hrpSize.X, hrpSize.Z) / 2
        
        -- Парт должен быть ВПЕРЕДИ по направлению движения
        local forwardDistance = hrpRadius + 2.6 -- Дальше на 0.1 стад
        local forwardOffset = State.fly.lastMoveDir * forwardDistance
        
        -- Поднимаем парт ВЫШЕ
        local verticalOffset = Vector3.new(0, -hrpSize.Y * 0.3, 0) -- Выше чем было
        
        local partPosition = State.fly.hr.Position + forwardOffset + verticalOffset
        
        -- Применяем bypass если включен
        if State.flyS.fly_bypass then
            local bMode = State.flyS.fly_bypass_mode
            
            if bMode == "Jitter" then
                -- Добавляем случайное дрожание к позиции парта
                partPosition = partPosition + Vector3.new(
                    math.random(-10, 10) / 100,
                    math.random(-10, 10) / 100,
                    math.random(-10, 10) / 100
                )
            elseif bMode == "Teleport" then
                -- Периодически телепортируем парт
                if tick() - State.fly.lastBypassTime > 0.1 then
                    partPosition = partPosition + Vector3.new(
                        math.random(-20, 20) / 100,
                        math.random(-20, 20) / 100,
                        math.random(-20, 20) / 100
                    )
                    State.fly.lastBypassTime = tick()
                end
            elseif bMode == "Hybrid" then
                -- Комбинация Velocity и Teleport
                if tick() - State.fly.lastBypassTime > 0.15 then
                    partPosition = partPosition + Vector3.new(
                        math.random(-15, 15) / 100,
                        math.random(-15, 15) / 100,
                        math.random(-15, 15) / 100
                    )
                    State.fly.lastBypassTime = tick()
                end
            elseif bMode == "Smooth" then
                -- Плавное движение парта
                State.fly.bypassPhase = State.fly.bypassPhase + 0.05
                partPosition = partPosition + Vector3.new(
                    math.sin(State.fly.bypassPhase) * 0.1,
                    math.cos(State.fly.bypassPhase * 2) * 0.05,
                    math.sin(State.fly.bypassPhase * 1.5) * 0.1
                )
            end
        end
        
        -- Размещаем ГОРИЗОНТАЛЬНЫЙ парт
        State.fly.climbPart.CFrame = CFrame.new(partPosition)
        
        -- Принудительно ставим Humanoid в состояние Climbing
        if hm:GetState() ~= Enum.HumanoidStateType.Climbing then
            hm:ChangeState(Enum.HumanoidStateType.Climbing)
        end
        
        -- КОНТРОЛЬ СКОРОСТИ - убираем ускорение
        local currentVel = State.fly.hr.Velocity
        local horizontalVel = Vector3.new(currentVel.X, 0, currentVel.Z)
        local horizontalSpeed = horizontalVel.Magnitude
        
        -- Ограничиваем горизонтальную скорость
        local maxSpeed = 16 * State.flyS.fly_speed -- Нормальная скорость ходьбы
        if horizontalSpeed > maxSpeed then
            local limitedVel = horizontalVel.Unit * maxSpeed
            State.fly.hr.Velocity = Vector3.new(limitedVel.X, currentVel.Y, limitedVel.Z)
        end
        
        -- Применяем bypass к velocity если включен
        if State.flyS.fly_bypass then
            local bMode = State.flyS.fly_bypass_mode
            
            if bMode == "Velocity" then
                -- Добавляем случайные колебания к velocity
                State.fly.hr.Velocity = State.fly.hr.Velocity + Vector3.new(
                    math.random(-5, 5),
                    math.random(-3, 3),
                    math.random(-5, 5)
                )
            elseif bMode == "Jitter" then
                -- Резкие изменения velocity
                if tick() - State.fly.lastBypassTime > 0.05 then
                    State.fly.hr.Velocity = State.fly.hr.Velocity + Vector3.new(
                        math.random(-10, 10),
                        math.random(-5, 5),
                        math.random(-10, 10)
                    )
                end
            end
        end
        
        -- Ограничиваем вертикальную скорость
        if currentVel.Y > 20 then
            State.fly.hr.Velocity = Vector3.new(currentVel.X, 20, currentVel.Z)
        elseif currentVel.Y < -20 then
            State.fly.hr.Velocity = Vector3.new(currentVel.X, -20, currentVel.Z)
        end
    end)
end

local function Fly_Mode_Seat()
    -- Создаем невидимое сиденье
    State.fly.seat = Instance.new("Seat", workspace)
    State.fly.seat.Name = "FlySeat"
    State.fly.seat.Size = Vector3.new(2, 0.5, 2)
    State.fly.seat.Anchored = false
    State.fly.seat.CanCollide = false
    State.fly.seat.Transparency = 1
    State.fly.seat.CastShadow = false
    
    -- Позиционируем сиденье
    State.fly.seat.CFrame = State.fly.hr.CFrame * CFrame.new(0, -2, 0)
    
    -- Делаем сиденье невесомым
    local bodyVelocity = Instance.new("BodyVelocity", State.fly.seat)
    bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    State.fly.bodyVelocity = bodyVelocity
    
    local bodyGyro = Instance.new("BodyGyro", State.fly.seat)
    bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bodyGyro.P = 9e4
    State.fly.bodyGyro = bodyGyro
    
    -- Принудительно сажаем персонажа
    State.fly.hm.Sit = true
    
    -- Создаем Weld чтобы привязать персонажа к сиденью
    local weld = Instance.new("Weld", State.fly.seat)
    weld.Part0 = State.fly.seat
    weld.Part1 = State.fly.hr
    weld.C0 = CFrame.new(0, 2, 0)
    State.fly.weld = weld
    
    State.fly.connection = G.RS.Heartbeat:Connect(function()
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.seat and State.fly.bodyVelocity and State.fly.bodyGyro) then 
            Fly_Cleanup() 
            return 
        end
        
        local hm = State.fly.hm
        if not hm then Fly_Cleanup() return end
        
        -- Управление направлением
        State.fly.bodyGyro.CFrame = G.Cam.CFrame
        
        -- Получаем направление движения
        getFlyMoveDirection()
        
        -- Применяем движение с bypass
        if State.fly.bypass then
            local bMode = State.fly.bMode
            if bMode == "Jitter" and tick() - State.fly.lastVel > 0.03 then
                State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50) + Vector3.new(math.random(-10, 10)/10, math.random(-10, 10)/10, math.random(-10, 10)/10)
                State.fly.lastVel = tick()
            elseif bMode == "Smooth" then
                State.fly.bodyVelocity.Velocity = State.fly.bodyVelocity.Velocity:Lerp(State.flyDir * (State.flyS.fly_speed * 50), 0.1)
            elseif bMode == "Velocity" then
                State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50) + Vector3.new(math.random(-15, 15), math.random(-15, 15), math.random(-15, 15))
            elseif bMode == "Teleport" and tick() - State.fly.lastVel > 0.1 then
                State.fly.seat.CFrame = State.fly.seat.CFrame + State.flyDir * (State.flyS.fly_speed * 2)
                State.fly.lastVel = tick()
            elseif bMode == "Hybrid" then
                if tick() - State.fly.lastVel > 0.08 then
                    State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50) + Vector3.new(math.random(-20, 20), math.random(-10, 10), math.random(-20, 20))
                    State.fly.lastVel = tick()
                else
                    State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
                end
            else
                State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
            end
        else
            State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
        end
    end)
end

local function Fly_Mode_Test()
    -- Режим Test - комбинация всех техник обхода античита
    State.fly.testMode = "natural" -- natural, hover, climb, diagonal
    State.fly.lastGroundTouch = tick()
    State.fly.touchCooldown = 0
    State.fly.microOffset = 0
    State.fly.naturalPhase = 0
    
    -- Добавляем BodyGyro для контроля вращения
    State.fly.bodyGyro = Instance.new("BodyGyro", State.fly.hr)
    State.fly.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.fly.bodyGyro.P = 9e4
    State.fly.bodyGyro.D = 500
    
    State.fly.connection = G.RS.Heartbeat:Connect(function(dt)
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.hm) then 
            Fly_Cleanup() 
            return 
        end
        
        -- Контроль вращения камерой
        State.fly.bodyGyro.CFrame = G.Cam.CFrame
        
        getFlyMoveDirection()
        local moveSpeed = State.flyS.fly_speed * 16
        
        -- Микроколебания для имитации естественного движения
        State.fly.microOffset = State.fly.microOffset + dt * 3
        local microShake = Vector3.new(
            math.sin(State.fly.microOffset * 2.3) * 0.02,
            math.sin(State.fly.microOffset * 1.7) * 0.015,
            math.sin(State.fly.microOffset * 2.1) * 0.02
        )
        
        -- Естественное движение с плавным подъемом
        if State.flyDir.Magnitude > 0 then
            local horizontal = Vector3.new(State.flyDir.X, 0, State.flyDir.Z).Unit
            local verticalComponent = State.flyDir.Y
            
            -- Диагональный подъем (выглядит естественно)
            local targetVel = horizontal * moveSpeed + Vector3.new(0, verticalComponent * moveSpeed * 0.6, 0)
            
            -- Добавляем микроколебания
            targetVel = targetVel + microShake
            
            -- Плавное изменение velocity
            State.fly.hr.Velocity = State.fly.hr.Velocity:Lerp(targetVel, 0.15)
        else
            -- Ровная высота с микроколебаниями
            local currentVel = State.fly.hr.Velocity
            State.fly.hr.Velocity = Vector3.new(
                currentVel.X * 0.9,
                math.sin(State.fly.microOffset) * 0.5, -- Микроколебания по Y
                currentVel.Z * 0.9
            )
        end
        
        -- Ложные посадки - периодически касаемся земли
        if tick() - State.fly.lastGroundTouch > math.random(3, 6) then
            -- Быстро опускаемся и поднимаемся
            State.fly.touchCooldown = 0.3
            State.fly.lastGroundTouch = tick()
        end
        
        if State.fly.touchCooldown > 0 then
            State.fly.touchCooldown = State.fly.touchCooldown - dt
            -- Быстрое касание земли
            local downSpeed = 30
            State.fly.hr.Velocity = Vector3.new(State.fly.hr.Velocity.X, -downSpeed, State.fly.hr.Velocity.Z)
            
            -- Проверяем касание земли
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {State.fly.ch}
            rayParams.FilterType = Enum.RaycastFilterType.Blacklist
            local ray = workspace:Raycast(State.fly.hr.Position, Vector3.new(0, -5, 0), rayParams)
            
            if ray or State.fly.touchCooldown <= 0 then
                -- Быстро поднимаемся обратно
                State.fly.hr.Velocity = Vector3.new(State.fly.hr.Velocity.X, 25, State.fly.hr.Velocity.Z)
                State.fly.touchCooldown = 0
            end
        end
        
        -- Избегаем состояния Freefall
        if State.fly.hm:GetState() == Enum.HumanoidStateType.Freefall then
            State.fly.hm:ChangeState(Enum.HumanoidStateType.Flying)
        end
    end)
end

local function Fly_Mode_Lags()
    -- Режим Lags - замораживаем сетевые пакеты для имитации лагов
    State.fly.bodyGyro = Instance.new("BodyGyro", State.fly.hr)
    State.fly.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.fly.bodyGyro.P = 9e4
    
    State.fly.bodyVelocity = Instance.new("BodyVelocity", State.fly.hr)
    State.fly.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    State.fly.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    
    -- Замораживаем network replication
    State.fly.lagPhase = 0
    State.fly.lagDuration = 0
    State.fly.isLagging = false
    State.fly.savedPosition = State.fly.hr.CFrame
    
    -- Отключаем network ownership для создания эффекта лага
    pcall(function()
        State.fly.hr:SetNetworkOwner(nil)
    end)
    
    State.fly.connection = G.RS.Heartbeat:Connect(function(dt)
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.bodyGyro and State.fly.bodyVelocity) then 
            Fly_Cleanup() 
            return 
        end
        
        State.fly.bodyGyro.CFrame = G.Cam.CFrame
        getFlyMoveDirection()
        
        -- Цикл лагов: двигаемся -> замораживаемся -> двигаемся
        State.fly.lagPhase = State.fly.lagPhase + dt
        
        if not State.fly.isLagging then
            -- Фаза движения (0.5-1 секунда)
            State.fly.bodyVelocity.Velocity = State.flyDir * (State.flyS.fly_speed * 50)
            
            if State.fly.lagPhase > math.random(50, 100) / 100 then
                -- Начинаем лаг
                State.fly.isLagging = true
                State.fly.savedPosition = State.fly.hr.CFrame
                State.fly.lagDuration = math.random(20, 50) / 100 -- 0.2-0.5 секунд лага
                State.fly.lagPhase = 0
            end
        else
            -- Фаза лага - замораживаем позицию
            State.fly.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
            
            -- Принудительно возвращаем на сохраненную позицию (имитация заморозки пакетов)
            State.fly.hr.CFrame = State.fly.savedPosition
            State.fly.hr.Velocity = Vector3.new(0, 0, 0)
            State.fly.hr.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            
            State.fly.lagPhase = State.fly.lagPhase + dt
            
            if State.fly.lagPhase >= State.fly.lagDuration then
                -- Заканчиваем лаг
                State.fly.isLagging = false
                State.fly.lagPhase = 0
            end
        end
    end)
end

local function Fly_Mode_Legit()
    -- ═══════════════════════════════════════════════════════════════════════════
    -- LEGIT FLY - SCAFFOLD MODE V2 (Без джиттера)
    -- ═══════════════════════════════════════════════════════════════════════════
    -- Стратегия:
    -- 1. Создаём БОЛЬШУЮ платформу под ногами (персонаж всегда на ней)
    -- 2. Платформа плавно движется вместе с персонажем
    -- 3. НЕТ коррекции Velocity = НЕТ джиттера
    -- 4. Персонаж ХОДИТ по платформе (состояние Running)
    -- ═══════════════════════════════════════════════════════════════════════════
    
    -- Инициализация
    State.fly.platform = nil
    State.fly.targetHeight = State.fly.hr.Position.Y
    State.fly.heightChangeSpeed = 0.4 -- Скорость изменения высоты
    State.fly.smoothing = 0.15 -- Плавность движения платформы
    
    -- Создаём платформу
    State.fly.platform = Instance.new("Part")
    State.fly.platform.Size = Vector3.new(12, 1, 12) -- Большая платформа
    State.fly.platform.Transparency = 1
    State.fly.platform.Anchored = true
    State.fly.platform.CanCollide = true
    State.fly.platform.Name = "LegitPlatform_" .. math.random(1000, 9999)
    State.fly.platform.Material = Enum.Material.SmoothPlastic
    State.fly.platform.CastShadow = false
    State.fly.platform.Position = State.fly.hr.Position - Vector3.new(0, 3, 0)
    State.fly.platform.Parent = workspace
    
    -- Отключаем сетевую репликацию
    pcall(function()
        State.fly.platform:SetNetworkOwner(nil)
    end)
    
    -- Сохраняем оригинальные значения
    State.fly.originalWalkSpeed = State.fly.hm.WalkSpeed
    State.fly.originalJumpPower = State.fly.hm.JumpPower
    State.fly.originalJumpHeight = State.fly.hm.JumpHeight
    
    -- Настройка Humanoid
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Flying, false)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
    
    -- Безопасная высота прыжка
    if State.fly.hm.UseJumpPower then
        State.fly.hm.JumpPower = 20
    else
        State.fly.hm.JumpHeight = 2
    end
    
    State.fly.connection = G.RS.Heartbeat:Connect(function(dt)
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.hm and State.fly.platform) then 
            -- Удаляем платформу при выключении
            if State.fly.platform then
                pcall(function() State.fly.platform:Destroy() end)
                State.fly.platform = nil
            end
            Fly_Cleanup() 
            return 
        end
        
        getFlyMoveDirection()
        
        local moveSpeed = State.flyS.fly_speed * 16
        local hrPos = State.fly.hr.Position
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- УПРАВЛЕНИЕ ЦЕЛЕВОЙ ВЫСОТОЙ
        -- ═══════════════════════════════════════════════════════════════════════
        if State.flyDir.Y > 0 then
            -- Движение вверх
            State.fly.targetHeight = State.fly.targetHeight + (State.fly.heightChangeSpeed * dt * 60)
        elseif State.flyDir.Y < 0 then
            -- Движение вниз
            State.fly.targetHeight = State.fly.targetHeight - (State.fly.heightChangeSpeed * dt * 60)
        end
        
        -- Проверяем землю
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {State.fly.ch, State.fly.platform}
        rayParams.FilterType = Enum.RaycastFilterType.Blacklist
        
        local rayResult = workspace:Raycast(hrPos, Vector3.new(0, -100, 0), rayParams)
        
        if rayResult then
            local groundHeight = rayResult.Position.Y
            State.fly.targetHeight = math.max(State.fly.targetHeight, groundHeight + 3)
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ПЛАВНОЕ ДВИЖЕНИЕ ПЛАТФОРМЫ (без джиттера)
        -- ═══════════════════════════════════════════════════════════════════════
        local currentPlatformPos = State.fly.platform.Position
        local targetPlatformY = State.fly.targetHeight - 3
        
        -- Плавная интерполяция позиции платформы
        local newPlatformPos = Vector3.new(
            hrPos.X,
            currentPlatformPos.Y + ((targetPlatformY - currentPlatformPos.Y) * State.fly.smoothing),
            hrPos.Z
        )
        
        State.fly.platform.Position = newPlatformPos
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ГОРИЗОНТАЛЬНОЕ ДВИЖЕНИЕ
        -- ═══════════════════════════════════════════════════════════════════════
        if State.flyDir.Magnitude > 0 then
            State.fly.hm.WalkSpeed = moveSpeed
            
            -- Обычное движение через Humanoid
            local horizontalDir = Vector3.new(State.flyDir.X, 0, State.flyDir.Z)
            if horizontalDir.Magnitude > 0 then
                State.fly.hm:Move(horizontalDir, false)
            end
        else
            State.fly.hm.WalkSpeed = State.fly.originalWalkSpeed
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ОГРАНИЧЕНИЯ (только для экстремальных случаев)
        -- ═══════════════════════════════════════════════════════════════════════
        local currentVel = State.fly.hr.Velocity
        
        -- Ограничение только если скорость ОЧЕНЬ большая
        if currentVel.Y > 15 then
            State.fly.hr.Velocity = Vector3.new(currentVel.X, 15, currentVel.Z)
        elseif currentVel.Y < -60 then
            State.fly.hr.Velocity = Vector3.new(currentVel.X, -60, currentVel.Z)
        end
        
        -- Ограничение горизонтальной скорости
        local horizontalSpeed = math.sqrt(currentVel.X^2 + currentVel.Z^2)
        if horizontalSpeed > moveSpeed * 1.3 then
            local scale = (moveSpeed * 1.3) / horizontalSpeed
            State.fly.hr.Velocity = Vector3.new(
                currentVel.X * scale,
                currentVel.Y,
                currentVel.Z * scale
            )
        end
    end)
end

local function Fly_Init()
    Fly_Cleanup()
    if not getgenv().aim_settings.fly_enabled then return end
    
    State.fly = {ch = G.LP.Character}
    if not State.fly.ch then return end
    State.fly.hr = State.fly.ch:FindFirstChild("HumanoidRootPart")
    State.fly.hm = State.fly.ch:FindFirstChildOfClass("Humanoid")
    if not State.fly.hr then return end
    
    State.flyS = getgenv().aim_settings
    State.fly.mode = State.flyS.fly_mode
    State.fly.stateChangeDelay = 0.15
    
    -- Создаём пул невидимых платформ с улучшенными свойствами
    for i = 1, State.fly.maxParts do
        local part = Instance.new("Part")
        -- Рандомизация размера для обхода детекта паттернов
        local sizeVariation = (math.random(70, 90) / 10)
        part.Size = Vector3.new(sizeVariation, 0.4, sizeVariation)
        part.Transparency = 1
        part.Anchored = true
        part.CanCollide = true
        part.Name = "LP_" .. math.random(1000, 9999)
        part.Material = Enum.Material.ForceField
        part.CastShadow = false
        part.Parent = workspace
        
        -- Отключаем сетевую репликацию
        pcall(function()
            part:SetNetworkOwner(nil)
        end)
        
        -- Делаем парт невидимым через дополнительные свойства
        pcall(function()
            part.LocalTransparencyModifier = 1
        end)
        
        table.insert(State.fly.parts, {
            part = part, 
            spawnTime = 0, 
            active = false,
            offset = Vector3.new(math.random(-10, 10) / 100, 0, math.random(-10, 10) / 100)
        })
    end
    
    -- BodyGyro для плавного поворота
    State.fly.bodyGyro = Instance.new("BodyGyro", State.fly.hr)
    State.fly.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.fly.bodyGyro.P = 8e4 -- Немного снижено для плавности
    State.fly.bodyGyro.D = 500 -- Добавлено демпфирование
    
    -- Настройка состояний Humanoid для легитимности
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true) -- Разрешаем падение
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Flying, false)
    State.fly.hm:SetStateEnabled(Enum.HumanoidStateType.Freefall, true) -- Разрешаем свободное падение
    
    -- Сохраняем оригинальные значения
    State.fly.originalWalkSpeed = State.fly.hm.WalkSpeed
    State.fly.originalJumpPower = State.fly.hm.JumpPower
    
    State.fly.connection = G.RS.Heartbeat:Connect(function(dt)
        if not (State.flyS.fly_enabled and State.fly.ch and State.fly.hr and State.fly.hm and State.fly.bodyGyro) then 
            Fly_Cleanup() 
            return 
        end
        
        -- Плавное вращение камеры
        State.fly.bodyGyro.CFrame = State.fly.bodyGyro.CFrame:Lerp(G.Cam.CFrame, 0.15)
        getFlyMoveDirection()
        
        local moveSpeed = State.flyS.fly_speed * 16
        local currentTime = tick()
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ПРОВЕРКА БЛИЗОСТИ К ЗЕМЛЕ (для адаптивного поведения)
        -- ═══════════════════════════════════════════════════════════════════════
        if currentTime - State.fly.lastGroundCheck >= State.fly.groundCheckInterval then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {State.fly.ch}
            rayParams.FilterType = Enum.RaycastFilterType.Blacklist
            
            local rayResult = workspace:Raycast(
                State.fly.hr.Position, 
                Vector3.new(0, -15, 0), 
                rayParams
            )
            
            State.fly.isNearGround = rayResult ~= nil
            State.fly.lastGroundCheck = currentTime
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- МИКРО-КОЛЕБАНИЯ ДЛЯ ЕСТЕСТВЕННОСТИ
        -- ═══════════════════════════════════════════════════════════════════════
        State.fly.microTime = State.fly.microTime + dt
        State.fly.microOffset = Vector3.new(
            math.sin(State.fly.microTime * 3.2) * 0.015,
            math.sin(State.fly.microTime * 2.1) * 0.02 + math.cos(State.fly.microTime * 1.5) * 0.015,
            math.cos(State.fly.microTime * 2.8) * 0.015
        )
        
        -- Вариация высоты для имитации неровной ходьбы
        State.fly.heightVariation = math.sin(State.fly.microTime * 4.5) * 0.08
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- УПРАВЛЕНИЕ ПЛАТФОРМАМИ
        -- ═══════════════════════════════════════════════════════════════════════
        -- Удаляем старые платформы
        for i, partData in ipairs(State.fly.parts) do
            if partData.active and (currentTime - partData.spawnTime) > State.fly.partLifetime then
                -- Плавно опускаем платформу вниз перед удалением
                tw(partData.part, {CFrame = CFrame.new(0, -1000, 0)}, 0.2)
                task.delay(0.2, function()
                    if partData.part then
                        partData.part.CFrame = CFrame.new(0, -1000, 0)
                    end
                end)
                partData.active = false
            end
        end
        
        -- Создаём новую платформу с рандомизированным интервалом
        local spawnInterval = 0.25 + math.random() * 0.15 -- 0.25-0.4 секунды
        if currentTime >= State.fly.nextPartTime then
            local partData = State.fly.parts[State.fly.partIndex]
            
            if partData then
                local hrPos = State.fly.hr.Position
                
                -- Позиция платформы с учётом микро-колебаний и вариации
                local partYOffset = -3.2 + State.fly.heightVariation
                local partPos = Vector3.new(
                    hrPos.X + partData.offset.X + State.fly.microOffset.X,
                    hrPos.Y + partYOffset,
                    hrPos.Z + partData.offset.Z + State.fly.microOffset.Z
                )
                
                -- Рандомизация угла поворота платформы
                local randomRotation = CFrame.Angles(
                    math.rad(math.random(-2, 2)),
                    math.rad(math.random(0, 360)),
                    math.rad(math.random(-2, 2))
                )
                
                partData.part.CFrame = CFrame.new(partPos) * randomRotation
                partData.spawnTime = currentTime
                partData.active = true
                State.fly.currentPart = partData.part
            end
            
            -- Переход к следующей платформе
            State.fly.partIndex = State.fly.partIndex + 1
            if State.fly.partIndex > State.fly.maxParts then
                State.fly.partIndex = 1
            end
            
            State.fly.nextPartTime = currentTime + spawnInterval
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ДВИЖЕНИЕ С АДАПТИВНОЙ ФИЗИКОЙ
        -- ═══════════════════════════════════════════════════════════════════════
        if State.flyDir.Magnitude > 0 then
            -- Адаптивная скорость в зависимости от близости к земле
            local adaptiveSpeed = State.fly.isNearGround and (moveSpeed * 0.85) or moveSpeed
            State.fly.hm.WalkSpeed = adaptiveSpeed
            
            -- Естественное движение через Humanoid
            State.fly.hm:Move(State.flyDir, false)
            
            -- Плавная коррекция velocity с учётом микро-колебаний
            local targetVel = State.flyDir * adaptiveSpeed
            local currentVel = State.fly.hr.Velocity
            
            -- Добавляем небольшие колебания к velocity для естественности
            local velocityNoise = Vector3.new(
                math.sin(State.fly.microTime * 5.3) * 0.3,
                math.cos(State.fly.microTime * 3.7) * 0.2,
                math.sin(State.fly.microTime * 4.1) * 0.3
            )
            
            State.fly.hr.Velocity = currentVel:Lerp(targetVel + velocityNoise, State.fly.velocitySmoothing)
            
            -- Имитация инерции при изменении направления
            local velocityDiff = (targetVel - currentVel).Magnitude
            if velocityDiff > 5 then
                State.fly.velocitySmoothing = 0.15 -- Медленнее при резких поворотах
            else
                State.fly.velocitySmoothing = 0.25 -- Быстрее при плавном движении
            end
        else
            -- Плавная остановка с имитацией трения
            State.fly.hm.WalkSpeed = State.fly.originalWalkSpeed
            local currentVel = State.fly.hr.Velocity
            State.fly.hr.Velocity = Vector3.new(
                currentVel.X * 0.88,
                currentVel.Y * 0.95,
                currentVel.Z * 0.88
            )
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- УМНОЕ УПРАВЛЕНИЕ СОСТОЯНИЯМИ
        -- ═══════════════════════════════════════════════════════════════════════
        local currentState = State.fly.hm:GetState()
        
        -- Разрешаем кратковременное падение для естественности
        if currentTime - State.fly.lastStateChange >= State.fly.stateChangeDelay then
            if currentState == Enum.HumanoidStateType.Freefall or 
               currentState == Enum.HumanoidStateType.FallingDown then
                -- Возвращаем в состояние бега только если прошло достаточно времени
                if math.random() > 0.3 then -- 70% шанс вернуться в бег
                    State.fly.hm:ChangeState(Enum.HumanoidStateType.Running)
                    State.fly.lastStateChange = currentTime
                end
            elseif currentState ~= Enum.HumanoidStateType.Running and 
                   currentState ~= Enum.HumanoidStateType.RunningNoPhysics then
                -- Для других состояний возвращаем в бег
                State.fly.hm:ChangeState(Enum.HumanoidStateType.Running)
                State.fly.lastStateChange = currentTime
            end
        end
        
        -- ═══════════════════════════════════════════════════════════════════════
        -- ОГРАНИЧЕНИЕ СКОРОСТИ ПАДЕНИЯ (антидетект)
        -- ═══════════════════════════════════════════════════════════════════════
        if State.fly.hr.Velocity.Y < -50 then
            State.fly.hr.Velocity = Vector3.new(
                State.fly.hr.Velocity.X,
                -50,
                State.fly.hr.Velocity.Z
            )
        end
    end)
end

local function Fly_Init()
    Fly_Cleanup()
    if not getgenv().aim_settings.fly_enabled then return end
    
    State.fly = {ch = G.LP.Character}
    if not State.fly.ch then return end
    State.fly.hr = State.fly.ch:FindFirstChild("HumanoidRootPart")
    State.fly.hm = State.fly.ch:FindFirstChildOfClass("Humanoid")
    if not State.fly.hr then return end
    
    State.flyS = getgenv().aim_settings
    State.fly.mode = State.flyS.fly_mode
    State.fly.bypass = State.flyS.fly_bypass
    State.fly.bMode = State.flyS.fly_bypass_mode
    State.fly.lastTouch = tick()
    State.fly.lastVel = tick()
    State.fly.bCool = 0
    
    if State.fly.mode == "Gyro" then
        Fly_Mode_Gyro()
    elseif State.fly.mode == "CFrame" then
        Fly_Mode_CFrame()
    elseif State.fly.mode == "Platform" then
        Fly_Mode_Platform()
    elseif State.fly.mode == "Velocity" then
        Fly_Mode_Velocity()
    elseif State.fly.mode == "Climb" then
        Fly_Mode_Climb()
    elseif State.fly.mode == "Seat" then
        Fly_Mode_Seat()
    elseif State.fly.mode == "Test" then
        Fly_Mode_Test()
    elseif State.fly.mode == "Lags" then
        Fly_Mode_Lags()
    elseif State.fly.mode == "Legit" then
        Fly_Mode_Legit()
    else
        Fly_Mode_Tween()
    end
end

-- Clumsy Functions
local function Clumsy_Cleanup()
    if State.clumsy then
        if State.clumsy.connection then State.clumsy.connection:Disconnect() end
        if State.clumsy.bodyGyro then State.clumsy.bodyGyro:Destroy() end
        if State.clumsy.bodyVelocity then State.clumsy.bodyVelocity:Destroy() end
        if State.clumsy.weld then State.clumsy.weld:Destroy() end
        if State.clumsy.seat then State.clumsy.seat:Destroy() end
        if State.clumsy.clone then State.clumsy.clone:Destroy() end
        State.clumsy = {}
    end
end

local function Clumsy_Init()
    Clumsy_Cleanup()
    if not getgenv().aim_settings.clumsy_enabled then return end
    
    State.clumsy = {ch = G.LP.Character}
    if not State.clumsy.ch then return end
    State.clumsy.hr = State.clumsy.ch:FindFirstChild("HumanoidRootPart")
    State.clumsy.hm = State.clumsy.ch:FindFirstChildOfClass("Humanoid")
    if not State.clumsy.hr or not State.clumsy.hm then return end
    
    -- Создаем клон персонажа если Visualize включен
    if getgenv().aim_settings.clumsy_visualize then
        pcall(function()
            State.clumsy.clone = State.clumsy.ch:Clone()
            
            -- Удаляем скрипты из клона
            for _, obj in pairs(State.clumsy.clone:GetDescendants()) do
                if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
                    obj:Destroy()
                end
            end
            
            -- Делаем все части полупрозрачными и неколлизионными
            for _, obj in pairs(State.clumsy.clone:GetDescendants()) do
                if obj:IsA("BasePart") then
                    obj.Anchored = true
                    obj.CanCollide = false
                    obj.Transparency = 0.5
                end
            end
            
            -- Удаляем Humanoid из клона
            local cloneHumanoid = State.clumsy.clone:FindFirstChildOfClass("Humanoid")
            if cloneHumanoid then
                cloneHumanoid:Destroy()
            end
            
            -- Размещаем клон в workspace
            State.clumsy.clone.Parent = workspace
        end)
    end
    
    -- Создаем невидимое сиденье
    State.clumsy.seat = Instance.new("Seat", workspace)
    State.clumsy.seat.Name = "ClumsySeat"
    State.clumsy.seat.Size = Vector3.new(2, 0.5, 2)
    State.clumsy.seat.Anchored = false
    State.clumsy.seat.CanCollide = false
    State.clumsy.seat.Transparency = 1
    State.clumsy.seat.CastShadow = false
    
    -- Позиционируем сиденье
    State.clumsy.seat.CFrame = State.clumsy.hr.CFrame * CFrame.new(0, -2, 0)
    
    -- Делаем сиденье невесомым
    State.clumsy.bodyVelocity = Instance.new("BodyVelocity", State.clumsy.seat)
    State.clumsy.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    State.clumsy.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    
    State.clumsy.bodyGyro = Instance.new("BodyGyro", State.clumsy.seat)
    State.clumsy.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    State.clumsy.bodyGyro.P = 9e4
    
    -- Принудительно сажаем персонажа
    State.clumsy.hm.Sit = true
    
    -- Создаем Weld чтобы привязать персонажа к сиденью
    State.clumsy.weld = Instance.new("Weld", State.clumsy.seat)
    State.clumsy.weld.Part0 = State.clumsy.seat
    State.clumsy.weld.Part1 = State.clumsy.hr
    State.clumsy.weld.C0 = CFrame.new(0, 2, 0)
    
    State.clumsy.connection = G.RS.Heartbeat:Connect(function()
        local s = getgenv().aim_settings
        if not (s.clumsy_enabled and State.clumsy.ch and State.clumsy.hr and State.clumsy.seat and State.clumsy.bodyVelocity and State.clumsy.bodyGyro) then 
            Clumsy_Cleanup() 
            return 
        end
        
        -- Управление направлением
        State.clumsy.bodyGyro.CFrame = G.Cam.CFrame
        
        -- Получаем направление движения
        local moveDir = Vector3.new(0, 0, 0)
        if G.UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + G.Cam.CFrame.LookVector end
        if G.UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - G.Cam.CFrame.LookVector end
        if G.UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - G.Cam.CFrame.RightVector end
        if G.UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + G.Cam.CFrame.RightVector end
        if G.UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if G.UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir = moveDir - Vector3.new(0, 1, 0) end
        
        -- Применяем движение
        State.clumsy.bodyVelocity.Velocity = moveDir * s.clumsy_speed
    end)
end

