Movement.Speed = {
    Cleanup = function()
        if State.speed then
            if State.speed.connection then State.speed.connection:Disconnect() end
            if State.speed.hm and State.speed.originalWalkSpeed then
                State.speed.hm.WalkSpeed = State.speed.originalWalkSpeed
            end
            State.speed = {}
        end
    end,
    Init = function()
        Movement.Speed.Cleanup()
        if not getgenv().aim_settings.speed_enabled then return end

        State.speed = {ch = G.LP.Character}
        if not State.speed.ch then return end
        State.speed.hm = State.speed.ch:FindFirstChildOfClass("Humanoid")
        State.speed.hr = State.speed.ch:FindFirstChild("HumanoidRootPart")
        if not State.speed.hm or not State.speed.hr then return end

        State.speed.originalWalkSpeed = State.speed.hm.WalkSpeed
        State.speed.lastJump = 0

        State.speed.connection = G.RS.Heartbeat:Connect(function()
            local s = getgenv().aim_settings
            if not s.speed_enabled or not (State.speed.ch and State.speed.ch.Parent and State.speed.hm and State.speed.hr) then
                Movement.Speed.Cleanup()
                return
            end

            local hum = State.speed.hm
            local root = State.speed.hr
            local moveDirection = hum.MoveDirection
            local desiredSpeed = math.max(s.speed_speed or 26, 16)
            local currentVel = root.Velocity
            local horizontal = Vector3.new(currentVel.X, 0, currentVel.Z)

            hum.WalkSpeed = State.speed.originalWalkSpeed or 16

            if s.speed_bypass then
                if moveDirection.Magnitude > 0 then
                    local targetHorizontal = moveDirection.Unit * desiredSpeed
                    local smoothedHorizontal = horizontal:Lerp(targetHorizontal, 0.18)
                    root.Velocity = Vector3.new(smoothedHorizontal.X, currentVel.Y, smoothedHorizontal.Z)

                    local state = hum:GetState()
                    if tick() - State.speed.lastJump >= s.speed_jump_interval and state ~= Enum.HumanoidStateType.Freefall and state ~= Enum.HumanoidStateType.FallingDown and state ~= Enum.HumanoidStateType.Jumping then
                        hum:ChangeState(Enum.HumanoidStateType.Jumping)
                        State.speed.lastJump = tick()
                    end
                else
                    root.Velocity = Vector3.new(currentVel.X * 0.82, currentVel.Y, currentVel.Z * 0.82)
                end
            else
                if moveDirection.Magnitude > 0 then
                    local targetHorizontal = moveDirection.Unit * desiredSpeed
                    local pushedHorizontal = horizontal:Lerp(targetHorizontal, 0.32)
                    root.Velocity = Vector3.new(pushedHorizontal.X, currentVel.Y, pushedHorizontal.Z)
                elseif horizontal.Magnitude > 0.1 then
                    root.Velocity = Vector3.new(currentVel.X * 0.75, currentVel.Y, currentVel.Z * 0.75)
                end
            end
        end)
    end
}

Movement.SafeWalk = {
    Cleanup = function()
        if State.safeWalk then
            if State.safeWalk.connection then State.safeWalk.connection:Disconnect() end
            State.safeWalk = {}
        end
    end,
    Init = function()
        Movement.SafeWalk.Cleanup()
        if not getgenv().aim_settings.safe_walk_enabled then return end
        
        State.safeWalk = {ch = G.LP.Character}
        if not State.safeWalk.ch then return end
        State.safeWalk.hm = State.safeWalk.ch:FindFirstChildOfClass("Humanoid")
        State.safeWalk.hr = State.safeWalk.ch:FindFirstChild("HumanoidRootPart")
        if not State.safeWalk.hm or not State.safeWalk.hr then return end
        
        State.safeWalk.connection = G.RS.Heartbeat:Connect(function()
            if not getgenv().aim_settings.safe_walk_enabled or not (State.safeWalk.ch and State.safeWalk.ch.Parent and State.safeWalk.hr and State.safeWalk.hr.Parent and State.safeWalk.hm) then
                Movement.SafeWalk.Cleanup()
                return
            end
            
            -- Получаем направление движения от Humanoid
            local moveDirection = State.safeWalk.hm.MoveDirection
            
            -- Если персонаж пытается двигаться
            if moveDirection.Magnitude > 0.1 then
                -- Конвертируем направление движения в мировые координаты
                local worldMoveDirection = (State.safeWalk.hr.CFrame.RightVector * moveDirection.X) + (State.safeWalk.hr.CFrame.LookVector * moveDirection.Z)
                worldMoveDirection = worldMoveDirection.Unit
                
                -- Проверяем землю впереди (на расстоянии 2.5 стада)
                local checkDistance = 2.5
                local checkPosition = State.safeWalk.hr.Position + (worldMoveDirection * checkDistance)
                
                -- Луч идёт сверху вниз
                local rayOrigin = checkPosition + Vector3.new(0, 2, 0)
                local rayDirection = Vector3.new(0, -20, 0) -- Проверяем 20 стадов вниз
                
                local rayParams = RaycastParams.new()
                rayParams.FilterDescendantsInstances = {State.safeWalk.ch}
                rayParams.FilterType = Enum.RaycastFilterType.Blacklist
                rayParams.IgnoreWater = false
                
                local rayResult = workspace:Raycast(rayOrigin, rayDirection, rayParams)
                
                -- Если впереди нет земли - блокируем движение
                if not rayResult then
                    -- Обнуляем горизонтальную скорость, сохраняя вертикальную
                    local currentVel = State.safeWalk.hr.Velocity
                    State.safeWalk.hr.Velocity = Vector3.new(0, currentVel.Y, 0)
                    
                    -- Останавливаем движение через Humanoid
                    State.safeWalk.hm:Move(Vector3.new(0, 0, 0), false)
                    
                    -- Дополнительно: якорим персонажа на мгновение
                    State.safeWalk.hr.CFrame = State.safeWalk.hr.CFrame
                end
            end
        end)
    end
}

