local function shouldTrackPersistentPlayerEsp()
    local settings = getgenv().aim_settings
    return settings.esp_enabled or settings.friend_markers
end

local function clearTrackedPlayerEsp(player, skipVisualCleanup)
    local entry = State.playerEspRegistry[player]
    if not entry then return end

    disconnectSafe(entry.headWatcher)
    disconnectSafe(entry.ancestryWatcher)

    if not skipVisualCleanup and entry.character then
        clearCharacterVisuals(entry.character)
    end

    State.playerEspRegistry[player] = nil
end

local function ensureTrackedPlayerEsp(player, character)
    if not player or not character then return end

    local entry = State.playerEspRegistry[player]
    if not entry or entry.character ~= character then
        clearTrackedPlayerEsp(player, true)
        entry = {
            player = player,
            character = character
        }
        State.playerEspRegistry[player] = entry
    end

    local highlight = character:FindFirstChild("Y_ESP")
    if not highlight and shouldTrackPersistentPlayerEsp() then
        highlight = Instance.new("Highlight")
        highlight.Name = "Y_ESP"
        highlight.Parent = character
    end
    entry.highlight = highlight

    local head = character:FindFirstChild("Head")
    entry.head = head
    if head then
        local textGui = head:FindFirstChild("Y_ESP_Text")
        if not textGui and shouldTrackPersistentPlayerEsp() then
            textGui = Instance.new("BillboardGui")
            textGui.Name = "Y_ESP_Text"
            textGui.Size = UDim2.new(0, 200, 0, 100)
            textGui.StudsOffset = Vector3.new(0, 2, 0)
            textGui.AlwaysOnTop = true
            textGui.Parent = head
        end
        entry.billboardGui = textGui

        local textLabel = textGui and textGui:FindFirstChild("TextLabel")
        if textGui and not textLabel and shouldTrackPersistentPlayerEsp() then
            textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextSize = 14
            textLabel.TextStrokeTransparency = 0.5
            textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            textLabel.Parent = textGui
        end
        entry.textLabel = textLabel

        local friendMarker = head:FindFirstChild("Y_Friend_Marker")
        if not friendMarker and shouldTrackPersistentPlayerEsp() then
            friendMarker = Instance.new("BillboardGui")
            friendMarker.Name = "Y_Friend_Marker"
            friendMarker.Size = UDim2.new(0, 40, 0, 30)
            friendMarker.StudsOffset = Vector3.new(0, 3, 0)
            friendMarker.AlwaysOnTop = true
            friendMarker.Parent = head

            local diamond = Instance.new("Frame")
            diamond.Size = UDim2.new(0, 22, 0, 22)
            diamond.Position = UDim2.new(0.5, -11, 0.5, -11)
            diamond.AnchorPoint = Vector2.new(0.5, 0.5)
            diamond.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            diamond.BorderSizePixel = 0
            diamond.Rotation = 45
            diamond.Parent = friendMarker

            local diamondStroke = Instance.new("UIStroke")
            diamondStroke.Color = Color3.fromRGB(50, 200, 50)
            diamondStroke.Thickness = 2
            diamondStroke.Parent = diamond
        end
        entry.friendMarker = friendMarker
    else
        entry.billboardGui = nil
        entry.textLabel = nil
        entry.friendMarker = nil
    end

    disconnectSafe(entry.headWatcher)
    entry.headWatcher = character.ChildAdded:Connect(function(child)
        if child.Name == "Head" then
            ensureTrackedPlayerEsp(player, character)
        end
    end)

    disconnectSafe(entry.ancestryWatcher)
    entry.ancestryWatcher = character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            clearTrackedPlayerEsp(player, true)
        end
    end)
end

local function trackPlayerEsp(player)
    if State.playerEspConnections[player] then
        return
    end

    local connections = {}
    connections.characterAdded = player.CharacterAdded:Connect(function(character)
        clearTrackedPlayerEsp(player, true)
        if shouldTrackPersistentPlayerEsp() then
            ensureTrackedPlayerEsp(player, character)
        else
            State.playerEspRegistry[player] = {
                player = player,
                character = character
            }
        end
    end)
    connections.characterRemoving = player.CharacterRemoving:Connect(function(character)
        clearCharacterVisuals(character)
        clearTrackedPlayerEsp(player, true)
    end)
    State.playerEspConnections[player] = connections

    if player.Character then
        if shouldTrackPersistentPlayerEsp() then
            ensureTrackedPlayerEsp(player, player.Character)
        else
            State.playerEspRegistry[player] = {
                player = player,
                character = player.Character
            }
        end
    end
end

local function untrackPlayerEsp(player)
    local connections = State.playerEspConnections[player]
    if connections then
        disconnectSafe(connections.characterAdded)
        disconnectSafe(connections.characterRemoving)
        State.playerEspConnections[player] = nil
    end

    clearTrackedPlayerEsp(player)
end

local function refreshTrackedPlayerEsp()
    for _, player in ipairs(G.Plr:GetPlayers()) do
        if player.Character then
            ensureTrackedPlayerEsp(player, player.Character)
        end
    end
end

