function ensureWorldTweaksSky()
    if State.worldTweaks.sky and State.worldTweaks.sky.Parent then
        return State.worldTweaks.sky
    end

    State.worldTweaks.sky = G.Light:FindFirstChildOfClass("Sky")
    if not State.worldTweaks.sky then
        State.worldTweaks.sky = Instance.new("Sky")
        State.worldTweaks.sky.Name = "Y_WorldTweaksSky"
        State.worldTweaks.sky.Parent = G.Light
    end
    return State.worldTweaks.sky
end

